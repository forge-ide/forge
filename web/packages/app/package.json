{
  "name": "app",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:phase2": "playwright test tests/phase2",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "sync-monaco-host": "node scripts/sync-monaco-host.mjs",
    "predev": "pnpm --filter monaco-host build && pnpm sync-monaco-host",
    "prebuild": "pnpm --filter monaco-host build && pnpm sync-monaco-host"
  },
  "dependencies": {
    "@forge/design": "workspace:*",
    "@forge/ipc": "workspace:*",
    "@solidjs/router": "^0.15.1",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-notification": "^2.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.9.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.5"
  }
