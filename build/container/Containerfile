FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive
ARG NODE_VERSION=22.22.1
ARG VSCODE_ARCH=x64
ARG BUILD_COMMIT=""

# Layer 1 — System deps (union of ci + package modes)
RUN apt-get update && apt-get install -y --no-install-recommends \
	build-essential \
	pkg-config \
	libgtk-3-0 \
	libxkbfile-dev \
	libkrb5-dev \
	libgbm1 \
	rpm \
	fakeroot \
	dpkg \
	python3-apt \
	python3-dev \
	python3-pip \
	python3-toml \
	python3-yaml \
	git \
	ca-certificates \
	curl \
	xz-utils \
	patchelf \
	execstack \
	snapd \
	squashfs-tools \
	&& rm -rf /var/lib/apt/lists/*

# Layer 1b — snapcraft via pip (the apt snapcraft package is a transitional stub that requires the
# snap store; pip gives us the Python snapcraft that works in a container)
# snapcraft's setup.py calls `git describe` to determine its version; pip builds in a
# tempdir with no .git, so we seed a dummy repo and point GIT_DIR at it.
# snapcraft==4.8.1 pins pyyaml==5.3 and installs it as a pure-Python wheel (no C bindings).
# We then uninstall pip's pyyaml so Python falls back to the apt python3-yaml package
# (Ubuntu 22.04: pyyaml 5.4.1 compiled with libyaml C bindings), which satisfies snapcraft's
# CSafeDumper requirement. pyyaml 5.4.1 is API-compatible with 5.3.
RUN git init /pip-git && \
	git -C /pip-git config user.email "build@forge" && \
	git -C /pip-git config user.name "build" && \
	git -C /pip-git commit --allow-empty -m "init" && \
	git -C /pip-git tag -a 4.8.1 -m "4.8.1" && \
	GIT_DIR=/pip-git/.git pip3 install "snapcraft==4.8.1" && \
	python3 -c "\
import glob, re; \
import sysconfig; site = sysconfig.get_path('purelib'); \
files = glob.glob(site + '/snapcraft-*.dist-info/METADATA'); \
[open(f,'w').write(re.sub(r'(?i)(pyyaml)==5\.3', r'\1>=5.3', open(f).read())) for f in files]; \
print('Patched', files)" && \
	pip3 uninstall -y pyyaml && \
	python3 -c "from yaml import CSafeDumper; print('pyyaml C bindings OK')" && \
	rm -rf /pip-git && \
	ln -s /usr/local/share/snapcraft /usr/share/snapcraft && \
	mkdir -p /snap/core22 && \
	ln -s / /snap/core22/current

# Layer 1c — patch snapcraft linker detection to accept ld-linux-x86-64.so.2 style names
# snapcraft 4.8.1 only recognises ld-<version>.so but the x86_64 dynamic linker is
# ld-linux-x86-64.so.2; add core22 to the known linker versions and widen both regexes.
COPY build/container/patch-snapcraft-linker.py /tmp/patch-snapcraft-linker.py
RUN python3 /tmp/patch-snapcraft-linker.py && rm /tmp/patch-snapcraft-linker.py

# Layer 2 — Node.js (via tarball; arch detected at build time so --platform drives the right binary)
RUN ARCH=$(uname -m | sed 's/x86_64/x64/' | sed 's/aarch64/arm64/') && \
	curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${ARCH}.tar.xz" \
	| tar -xJ --strip-components=1 -C /usr/local

RUN useradd -m -s /bin/bash builder

ENV SNAPCRAFT_BUILD_ENVIRONMENT=host
ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV npm_config_arch=${VSCODE_ARCH}
ENV BUILD_SOURCEVERSION=${BUILD_COMMIT}

WORKDIR /workspace
RUN mkdir -p /workspace/forge && chown -R builder:builder /workspace

# Layer 3 — npm install (ordered so dep layers survive source changes)
# Step 1: root + build/ manifests only
COPY --chown=builder:builder package.json package-lock.json .npmrc .nvmrc /workspace/forge/
COPY --chown=builder:builder build/package.json build/package-lock.json build/.npmrc /workspace/forge/build/
COPY --chown=builder:builder build/npm/ /workspace/forge/build/npm/
COPY --chown=builder:builder remote/.npmrc /workspace/forge/remote/

USER builder
WORKDIR /workspace/forge

RUN npm ci --ignore-scripts
RUN cd build && npm ci --ignore-scripts

# Step 2: extension manifests
COPY --chown=builder:builder extensions/ /workspace/forge/extensions/
COPY --chown=builder:builder .vscode/extensions/ /workspace/forge/.vscode/extensions/

RUN find extensions .vscode/extensions -name "package-lock.json" -not -path "*/node_modules/*" \
	-execdir pwd \; | xargs -P 4 -I{} npm ci --prefix {} --ignore-scripts

# Step 3: full source (invalidates only compilation layers, not npm install layers)
USER root
COPY --chown=builder:builder . /workspace/forge/
USER builder

# Step 4: run postinstall now that full source is available
RUN node build/npm/postinstall.ts
