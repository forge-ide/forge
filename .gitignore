# Rust
target/
**/*.rs.bk

# Node / frontend
.pnpm-store/
node_modules/
web/**/dist/
web/**/.vite/
*.tsbuildinfo

# F-122: monaco-host build output is copied into app/public at predev/prebuild
# time. Tracking it would duplicate the source of truth; the copy is
# deterministic from `web/packages/monaco-host/dist/`.
web/packages/app/public/monaco-host/

# Playwright build artifacts
web/**/playwright-report/
web/**/test-results/

# Tauri
# Placeholder icons regenerated by forge-shell/build.rs until real branding lands
crates/forge-shell/icons/*.png
crates/forge-shell/icons/*.icns
crates/forge-shell/icons/*.ico
# tauri-build output (schemas, bindings) emitted into the crate root at
# build time — kept out of git because it regenerates on every build.
crates/forge-shell/gen/

# Generated (tracked intentionally — CI verifies drift)
# web/packages/ipc/src/generated/

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.*
