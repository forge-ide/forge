{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "env": { "FS_ROOT": "/tmp" },
      "envFile": ".env"
    },
    "remote": {
      "url": "https://mcp.example.com/api",
      "headers": { "Authorization": "Bearer ${env:MCP_TOKEN}" }
    }
  }
}
