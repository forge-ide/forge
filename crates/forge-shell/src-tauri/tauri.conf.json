{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "dev.forge-ide.forge",
  "build": {
    "frontendDist": "../../../web/packages/app/dist",
    "beforeBuildCommand": "pnpm --filter app build",
    "beforeDevCommand": "pnpm --filter app dev",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
