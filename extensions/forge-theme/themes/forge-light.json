	"tokenColors": [
		{
			"settings": {
				"foreground": "#1a1614"
			}
		},
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"foreground": "#a89f93",
				"fontStyle": "italic"
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"foreground": "#1a6e3d"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#c04400"
			}
		},
		{
			"name": "Language constant",
