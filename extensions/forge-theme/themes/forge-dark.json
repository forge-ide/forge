	"tokenColors": [
		{
			"settings": {
				"foreground": "#eae6de"
			}
		},
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"foreground": "#3a4558",
				"fontStyle": "italic"
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"foreground": "#3ddc84"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#ff9966"
			}
		},
		{
			"name": "Language constant",
			"scope": "constant.language",
			"settings": {
				"foreground": "#ffaa33"
			}
		},
		{
			"name": "User-defined constant",
